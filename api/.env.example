# Comply API — Variables d'environnement
# Copiez ce fichier en .env

CLAUDE_API_KEY=sk-ant-api03-...
MISTRAL_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=4096
TEMPERATURE=0.1
DATA_DIR=./data
VECTOR_DB_PATH=./chroma_db
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_CONTEXT_DOCS=6
MIN_CONFIDENCE=0.35
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
CNJE_TICKET_URL=https://support.junior-entreprises.com/hc/fr/requests/new
